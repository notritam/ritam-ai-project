# 
#  Ritam AI  Environment Variables
#  Copy this file to .env and fill in your values
#  Command: cp .env.example .env
# 

#  OpenAI API Key (REQUIRED) 
# Get yours at: https://platform.openai.com/api-keys
# This powers both the ScentAI and DriveIQ advisors
OPENAI_API_KEY=sk-your-api-key-here

#  OpenAI Model (Optional) 
# Default: gpt-4o-mini (fast & affordable)
# Upgrade to gpt-4o for higher quality responses
OPENAI_MODEL=gpt-4o-mini

#  Server Port (Optional) 
# Default: 3000
PORT=3000

#  CORS Allowed Origins (Optional) 
# Comma-separated list of frontend URLs allowed to call this API
# For local development, the defaults in server.js work fine
# For production, set this to your GitHub Pages URL
# Example: https://yourusername.github.io,https://yourdomain.com
ALLOWED_ORIGINS=

#  Environment (Optional) 
# Set to 'development' for detailed error messages
# Set to 'production' for clean error responses
NODE_ENV=development
